{
  "name": "live2d-desktop-pet",
  "version": "1.0.0",
  "description": "Live2D Desktop Pet with Chat UI - Hiyori",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "chcp 65001 > nul && electron-vite dev",
    "build": "chcp 65001 > nul && electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "pack:win": "chcp 65001 > nul && electron-vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.hiyori.desktop-pet",
    "productName": "Hiyori",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hiyori"
    },
    "npmRebuild": true,
    "nativeRebuilder": "sequential"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "global-agent": "^4.1.3",
    "playwright": "^1.58.2"
  }
}
