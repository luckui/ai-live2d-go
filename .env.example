# 复制本文件为 .env，填入你的真实密钥

# 豆包 / 火山引擎 API Key
DOUBAO_API_KEY=

# 如需在代码里预设其他服务商的 Key，在此添加，并在 ai.config.ts 中对应引用
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# ZHIPU_API_KEY=
# MOONSHOT_API_KEY=

# Discord 相关设置
DISCORD_ENABLED=true
DISCORD_TOKEN=          # 你的 Discord Bot Token，留空表示不启用 Discord 功能
DISCORD_ALLOWED_CHANNELS=           # 逗号分隔的频道 ID 列表，留空表示允许所有频道
DISCORD_CONVERSATION_ID=            # 可选：指定一个固定的对话 ID，所有消息都在这个对话里（不填则每次使用最近的对话）
DISCORD_PROXY=http://127.0.0.1:7890 # 可选：国内用户可能需要开启代理地址，留空表示不使用代理
